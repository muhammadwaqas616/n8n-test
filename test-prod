_logger = logging.getLogger(__name__)

_API_DATE_FORMAT = "%Y-%m-%d"
_API_TIME_FORMAT = "%H:%M"


def _api_date_serializer(v: datetime.date) -> str:
    return v.strftime(_API_DATE_FORMAT)


def _api_time_serializer(v: datetime.time) -> str:
    return v.strftime(_API_TIME_FORMAT)


_API_JSON_ENCODERS = {
    datetime.date: _api_date_serializer,
    datetime.time: _api_time_serializer,
}

_API_MODEL_CONFIG = ConfigDict(json_encoders=_API_JSON_ENCODERS, frozen=True)


class TimeRange(BaseModel):
    model_config = _API_MODEL_CONFIG

    start: datetime.time
    end: datetime.time

    @field_validator("start", "end", mode="before")
    @staticmethod
    def validate_time(v: Any) -> datetime.time:
        if isinstance(v, datetime.time):
            return v
        if v == "24:00":
            return datetime.time(0, 0)
        if not isinstance(v, str):
            raise ValueError("時間指定は文字列である必要があります")  # noqa: TRY004
        return datetime.datetime.strptime(v, _API_TIME_FORMAT).time()


class FixDetail(BaseModel):
    model_config = _API_MODEL_CONFIG

    time: TimeRange
    position: str


class Employee(BaseModel):
    model_config = _API_MODEL_CONFIG

    work_start_date: datetime.date
    employment_code: str
    required_staff: int = 0
    work: TimeRange
    fix: list[FixDetail] = []
    help: bool = False

    @field_validator("work_start_date", mode="before")
    @staticmethod
    def validate_date(v: Any) -> datetime.date:
        if isinstance(v, datetime.date):
            return v
        if not isinstance(v, str):
            raise ValueError("日付指定は文字列である必要があります")  # noqa: TRY004
        return datetime.datetime.strptime(v, _API_DATE_FORMAT).date()

    @field_validator("employment_code")
    @staticmethod
    def validate_employment_code(v: str) -> str:
        reason = None
        int_code = None

        try:
            int_code = int(v)
        except ValueError as e:
            reason = e
        if reason or int_code not in _EMPLOYMENT_CODES:
            raise ValueError("無効な雇用形態コードです") from reason
        return v


class Request(BaseModel):
    model_config = _API_MODEL_CONFIG

    store_code: str
    target_date: datetime.date
    shift: dict[str, Employee]

    @field_validator("target_date", mode="before")
    @staticmethod
    def validate_date(v: Any) -> datetime.date:
        if isinstance(v, datetime.date):
            return v
        if not isinstance(v, str):
            raise ValueError("日付指定は文字列である必要があります")  # noqa: TRY004
        return datetime.datetime.strptime(v, _API_DATE_FORMAT).date()

    @field_validator("shift")
    @staticmethod
    def validate_shift_keys(v: dict[str, Employee]) -> dict[str, Employee]:
        if "" in v:
            raise ValueError("社員番号に空文字は許可されません")
        return v


class TimeAssignment(BaseModel):
    model_config = _API_MODEL_CONFIG

    time: TimeRange
    position: str
    work_kind: int


class Response(BaseModel):
    model_config = _API_MODEL_CONFIG

    store_code: str
    target_date: datetime.date
    assign: dict[str, list[TimeAssignment]]
    peak: list[int]
    target_amount: dict[str, int]


